<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xiaoniucr.mapper.TransactionMapper">
    
    <resultMap id="BaseResultMap" type="com.xiaoniucr.entity.Transaction">
        <id column="id" jdbcType="INTEGER" property="id"/>
        <result column="user_id" jdbcType="INTEGER" property="userId"/>
        <result column="type" jdbcType="INTEGER" property="type"/>
        <result column="amount" jdbcType="DOUBLE" property="amount"/>
        <result column="description" jdbcType="VARCHAR" property="description"/>
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime"/>
        <result column="nickname" jdbcType="VARCHAR" property="nickname"/>
    </resultMap>

    <insert id="insert" parameterType="com.xiaoniucr.entity.Transaction">
        INSERT INTO t_transaction (user_id, type, amount, description, create_time)
        VALUES (#{userId}, #{type}, #{amount}, #{description}, 
        <choose>
            <when test="createTime != null">
                #{createTime}
            </when>
            <otherwise>
                NOW()
            </otherwise>
        </choose>)
    </insert>

    <select id="findList" resultMap="BaseResultMap">
        SELECT t.*, u.nickname
        FROM t_transaction t
        LEFT JOIN t_user u ON t.user_id = u.id
        <where>
            <if test="userId != null and userId != ''">
                AND t.user_id = #{userId}
            </if>
            <if test="type != null and type != ''">
                AND t.type = #{type}
            </if>
            <if test="beginTime != null and beginTime != ''">
                AND t.create_time &gt;= #{beginTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND t.create_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY t.create_time DESC
        LIMIT #{start}, #{limit}
    </select>

    <select id="findTotal" resultType="java.lang.Integer">
        SELECT COUNT(id)
        FROM t_transaction
        <where>
            <if test="userId != null and userId != ''">
                AND user_id = #{userId}
            </if>
            <if test="type != null and type != ''">
                AND type = #{type}
            </if>
            <if test="beginTime != null and beginTime != ''">
                AND create_time &gt;= #{beginTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
    </select>

    <select id="sumRechargeAmount" resultType="java.lang.Double">
        SELECT IFNULL(SUM(amount), 0)
        FROM t_transaction
        WHERE type = 1
        <if test="param1 != null and param1 != ''">
            AND create_time &gt;= #{param1}
        </if>
        <if test="param2 != null and param2 != ''">
            AND create_time &lt;= #{param2}
        </if>
    </select>

    <select id="sumRefundAmount" resultType="java.lang.Double">
        SELECT IFNULL(SUM(amount), 0)
        FROM t_transaction
        WHERE type = 3
        <if test="param1 != null and param1 != ''">
            AND create_time &gt;= #{param1}
        </if>
        <if test="param2 != null and param2 != ''">
            AND create_time &lt;= #{param2}
        </if>
    </select>

</mapper>
